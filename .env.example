# App
APP_NAME=KnoweTrade
APP_ENV=development
APP_MODE=paper
LOG_LEVEL=INFO

# API
API_PORT=8000
ADMIN_API_KEY=change-me

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Database (Supabase Postgres recommended)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/knowetrade

# Trading assumptions (v1 long-only ETFs loaded from DB symbols table)
STRATEGY_BUCKET=etf_trend
MAX_POSITION_NOTIONAL_USD=10000
DAILY_LOSS_THRESHOLD_PCT=-2.0
DAILY_PNL_PCT=0
RECONCILE_FORCE_MISMATCH=false
DRY_RUN=true
TRADING_ENABLED=false
ENABLE_ORDER_SUBMISSION=false
WORKER_JOB_NAME=etf_data_ingestion
WORKER_POLL_SECONDS=60
TARGET_POSITION_QTY_PER_SYMBOL=1
MAX_PORTFOLIO_POSITIONS=5
MAX_OPEN_POSITIONS=5
MAX_POSITION_PCT=0.20
ORDER_SUBMISSION_ENABLED=false
PAPER_ORDER_QTY=1
SUMMARY_INTERVAL_MINUTES=1440

# Alpaca
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_SECRET_KEY=

# Alerts
SLACK_ALERTS_ENABLED=true
SLACK_WEBHOOK_URL=
